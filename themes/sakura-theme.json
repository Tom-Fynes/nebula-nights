{
  "name": "Sakura",
  "type": "dark",
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "function": "#FFB8D0",
    "method": "#FFB8D0",
    "class": "#FF7BAC",
    "module": "#C890C8",
    "parameter": "#F9CEDE",
    "variable": "#F2CEE0",
    "property": "#E8A8F0",
    "type": "#F5B8CE",
    "enum": "#E8A8F0",
    "interface": "#F9CEDE"
  },
  "colors": {
    "editor.background": "#1E1520",
    "editor.foreground": "#F2CEE0",
    "activityBarBadge.background": "#E05080",
    "sideBarTitle.foreground": "#F2CEE0",
    "activityBar.background": "#120D14",
    "activityBar.foreground": "#F2CEE0",
    "activityBar.inactiveForeground": "#6E4E6B",
    "activityBar.activeBorder": "#E87FAA",
    "sideBar.background": "#180F1A",
    "sideBar.foreground": "#F2CEE0",
    "sideBarSectionHeader.background": "#2A1A28",
    "sideBarSectionHeader.foreground": "#F2CEE0",
    "editorGroupHeader.tabsBackground": "#180F1A",
    "tab.activeBackground": "#1E1520",
    "tab.inactiveBackground": "#180F1A",
    "tab.activeForeground": "#F2CEE0",
    "tab.inactiveForeground": "#6E4E6B",
    "tab.activeBorderTop": "#E87FAA",
    "statusBar.background": "#120D14",
    "statusBar.foreground": "#F2CEE0",
    "statusBar.noFolderBackground": "#120D14",
    "statusBar.debuggingBackground": "#E05080",
    "titleBar.activeBackground": "#120D14",
    "titleBar.activeForeground": "#F2CEE0",
    "menubar.selectionBackground": "#2A1A28",
    "menubar.selectionForeground": "#F2CEE0",
    "menu.background": "#180F1A",
    "menu.foreground": "#F2CEE0",
    "menu.selectionBackground": "#2A1A28",
    "menu.selectionForeground": "#F2CEE0",
    "quickInput.background": "#180F1A",
    "quickInput.foreground": "#F2CEE0",
    "editorWidget.background": "#180F1A",
    "editorWidget.foreground": "#F2CEE0",
    "notifications.background": "#180F1A",
    "notifications.foreground": "#F2CEE0",
    "breadcrumb.background": "#1E1520",
    "breadcrumb.foreground": "#F2CEE0",
    "progressBar.background": "#E87FAA",
    "terminal.background": "#1E1520",
    "terminal.foreground": "#F2CEE0",
    "terminal.ansiBlack": "#180F1A",
    "terminal.ansiBlue": "#B8D8F0",
    "terminal.ansiCyan": "#A0D8E8",
    "terminal.ansiGreen": "#90E0A0",
    "terminal.ansiMagenta": "#E8A8F0",
    "terminal.ansiRed": "#E05080",
    "terminal.ansiWhite": "#F2CEE0",
    "terminal.ansiYellow": "#F0D880",
    "terminal.ansiBrightBlack": "#2A1A28",
    "terminal.ansiBrightBlue": "#B8D8F0",
    "terminal.ansiBrightCyan": "#A0D8E8",
    "terminal.ansiBrightGreen": "#90E0A0",
    "terminal.ansiBrightMagenta": "#E8A8F0",
    "terminal.ansiBrightRed": "#F070A0",
    "terminal.ansiBrightWhite": "#F9CEDE",
    "terminal.ansiBrightYellow": "#F8E898",
    "editorBracketHighlight.foreground1": "#FFB8D0",
    "editorBracketHighlight.foreground2": "#C890C8",
    "editorBracketHighlight.foreground3": "#F5B8CE",
    "editorBracketHighlight.foreground4": "#E8A8F0",
    "editorBracketHighlight.foreground5": "#F9CEDE",
    "editorBracketHighlight.foreground6": "#A0D8E8",
    "editorError.foreground": "#E05080",
    "editorWarning.foreground": "#F0D880",
    "editorInfo.foreground": "#A0D8E8",
    "editorHint.foreground": "#7A5A78",
    "editorLineHighlight.background": "#2A1A2833",
    "editor.selectionBackground": "#6E4E6B66",
    "editor.wordHighlightBackground": "#E8A8F033",
    "editor.wordHighlightStrongBackground": "#F5B8CE33"
  },
  "tokenColors": [
    {
      "name": "Comments",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "foreground": "#7A5A78"
      }
    },
    {
      "name": "String",
      "scope": ["string", "constant.other.symbol"],
      "settings": {
        "foreground": "#F5B8CE"
      }
    },
    {
      "name": "Keywords",
      "scope": [
        "keyword",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#F070A0"
      }
    },
    {
      "name": "Functions",
      "scope": [
        "entity.name.function",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#FFB8D0"
      }
    },
    {
      "name": "Function parameters",
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#F9CEDE"
      }
    },
    {
      "name": "Function calls",
      "scope": [
        "variable.function",
        "meta.function-call.generic"
      ],
      "settings": {
        "foreground": "#FFB8D0",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Variables",
      "scope": [
        "variable",
        "support.variable"
      ],
      "settings": {
        "foreground": "#F2CEE0"
      }
    },
    {
      "name": "Classes",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace",
        "entity.name.scope-resolution"
      ],
      "settings": {
        "foreground": "#FF7BAC"
      }
    },
    {
      "name": "Numbers",
      "scope": "constant.numeric",
      "settings": {
        "foreground": "#FF9EC0"
      }
    },
    {
      "name": "Constants",
      "scope": "constant",
      "settings": {
        "foreground": "#E05080"
      }
    },
    {
      "name": "Tags",
      "scope": "entity.name.tag",
      "settings": {
        "foreground": "#F070A0"
      }
    },
    {
      "name": "Attributes",
      "scope": "entity.other.attribute-name",
      "settings": {
        "foreground": "#F2CEE0"
      }
    },
    {
      "name": "JSON Property Names",
      "scope": "support.type.property-name.json",
      "settings": {
        "foreground": "#F0D880"
      }
    },
    {
      "name": "JSON Property Values",
      "scope": "string.quoted.double.json",
      "settings": {
        "foreground": "#F5B8CE"
      }
    },
    {
      "name": "JSON Punctuation",
      "scope": [
        "punctuation.support.type.property-name.begin.json",
        "punctuation.support.type.property-name.end.json",
        "punctuation.separator.dictionary.key-value.json",
        "punctuation.definition.dictionary.begin.json",
        "punctuation.definition.dictionary.end.json",
        "punctuation.definition.array.begin.json",
        "punctuation.definition.array.end.json"
      ],
      "settings": {
        "foreground": "#C890C8"
      }
    },
    {
      "name": "Operators",
      "scope": "keyword.operator",
      "settings": {
        "foreground": "#C890C8"
      }
    },
    {
      "name": "Method calls",
      "scope": "meta.method-call entity.name.function",
      "settings": {
        "foreground": "#FFB8D0"
      }
    },
    {
      "name": "Method definition",
      "scope": "meta.method entity.name.function",
      "settings": {
        "foreground": "#FFB8D0"
      }
    },
    {
      "name": "Function definition",
      "scope": "meta.definition.function entity.name.function",
      "settings": {
        "foreground": "#FFB8D0"
      }
    },
    {
      "name": "SQL Keywords",
      "scope": [
        "keyword.control.flow.sql",
        "keyword.control.import.sql",
        "keyword.operator.logical.sql"
      ],
      "settings": {
        "foreground": "#F070A0",
        "fontStyle": "bold"
      }
    },
    {
      "name": "SQL Functions",
      "scope": [
        "support.function.builtin.sql"
      ],
      "settings": {
        "foreground": "#FFB8D0"
      }
    },
    {
      "name": "SQL Variables",
      "scope": [
        "variable.parameter.function.sql"
      ],
      "settings": {
        "foreground": "#F9CEDE"
      }
    },
    {
      "name": "SQL Constants",
      "scope": [
        "constant.language.sql"
      ],
      "settings": {
        "foreground": "#E05080",
        "fontStyle": "bold"
      }
    },
    {
      "name": "SQL Operators",
      "scope": [
        "keyword.operator.sql"
      ],
      "settings": {
        "foreground": "#C890C8"
      }
    },
    {
      "name": "SQL Table names",
      "scope": [
        "entity.name.type.table.sql"
      ],
      "settings": {
        "foreground": "#FFB8D0",
        "fontStyle": "bold"
      }
    },
    {
      "name": "SQL Column names",
      "scope": [
        "entity.name.type.column.sql"
      ],
      "settings": {
        "foreground": "#F2CEE0"
      }
    },
    {
      "name": "SQL String",
      "scope": [
        "string.quoted.single.sql",
        "string.quoted.double.sql"
      ],
      "settings": {
        "foreground": "#F5B8CE"
      }
    },
    {
      "name": "SQL Comments",
      "scope": [
        "comment.line.sql",
        "punctuation.definition.comment.sql"
      ],
      "settings": {
        "foreground": "#7A5A78"
      }
    },
    {
      "name": "SQL Punctuation",
      "scope": [
        "punctuation.definition.sql"
      ],
      "settings": {
        "foreground": "#C890C8"
      }
    },
    {
      "name": "Python decorators",
      "scope": [
        "meta.decorator.python",
        "entity.name.function.decorator.python"
      ],
      "settings": {
        "foreground": "#C890C8",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Python function parameters",
      "scope": [
        "variable.parameter.function.python"
      ],
      "settings": {
        "foreground": "#F9CEDE"
      }
    },
    {
      "name": "Python function call",
      "scope": [
        "meta.function-call.python",
        "meta.function-call.generic.python"
      ],
      "settings": {
        "foreground": "#FFB8D0"
      }
    },
    {
      "name": "Python builtin functions",
      "scope": [
        "support.function.builtin.python"
      ],
      "settings": {
        "foreground": "#F5B8CE",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Python self parameter",
      "scope": [
        "variable.parameter.function.language.special.self.python",
        "variable.language.special.self.python"
      ],
      "settings": {
        "foreground": "#FF7BAC",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Python class definitions",
      "scope": [
        "entity.name.type.class.python"
      ],
      "settings": {
        "foreground": "#FF7BAC",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Python module import",
      "scope": [
        "meta.import.python",
        "entity.name.namespace.python"
      ],
      "settings": {
        "foreground": "#C890C8"
      }
    },
    {
      "name": "Python f-string expressions",
      "scope": [
        "meta.fstring.python",
        "constant.character.format.placeholder.other.python"
      ],
      "settings": {
        "foreground": "#F5B8CE"
      }
    },
    {
      "name": "Python docstrings",
      "scope": [
        "string.quoted.docstring.multi.python"
      ],
      "settings": {
        "foreground": "#7A5A78",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Python magic methods",
      "scope": [
        "support.function.magic.python"
      ],
      "settings": {
        "foreground": "#F5B8CE",
        "fontStyle": "bold italic"
      }
    },
    {
      "name": "Python type hints",
      "scope": [
        "meta.function.annotation.return.python",
        "meta.function.parameters.annotation.python",
        "support.type.python"
      ],
      "settings": {
        "foreground": "#F5B8CE"
      }
    },
    {
      "name": "Python constants (True, False, None)",
      "scope": [
        "constant.language.python"
      ],
      "settings": {
        "foreground": "#E05080",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Python exceptions",
      "scope": [
        "support.type.exception.python"
      ],
      "settings": {
        "foreground": "#E05080",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Python keywords",
      "scope": [
        "keyword.control.flow.python",
        "keyword.control.import.python",
        "keyword.operator.logical.python"
      ],
      "settings": {
        "foreground": "#F070A0",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Python string interpolation",
      "scope": [
        "constant.character.format.placeholder.other.python"
      ],
      "settings": {
        "foreground": "#F0D880"
      }
    },
    {
      "name": "Python list/dict comprehension",
      "scope": [
        "meta.comprehension.python"
      ],
      "settings": {
        "foreground": "#F2CEE0"
      }
    },
    {
      "name": "Python lambda expressions",
      "scope": [
        "meta.lambda-function.python"
      ],
      "settings": {
        "foreground": "#C890C8"
      }
    },
    {
      "name": "TypeScript/JavaScript interfaces",
      "scope": [
        "entity.name.type.interface"
      ],
      "settings": {
        "foreground": "#F9CEDE",
        "fontStyle": "bold"
      }
    },
    {
      "name": "TypeScript/JavaScript enums",
      "scope": [
        "entity.name.type.enum"
      ],
      "settings": {
        "foreground": "#E8A8F0",
        "fontStyle": "bold"
      }
    },
    {
      "name": "HTML and XML attributes",
      "scope": [
        "entity.other.attribute-name.html",
        "entity.other.attribute-name.xml"
      ],
      "settings": {
        "foreground": "#90E0A0"
      }
    },
    {
      "name": "CSS Properties",
      "scope": [
        "support.type.property-name.css",
        "support.type.property-name.scss"
      ],
      "settings": {
        "foreground": "#A0D8E8"
      }
    },
    {
      "name": "CSS Values",
      "scope": [
        "support.constant.property-value.css"
      ],
      "settings": {
        "foreground": "#9878A8"
      }
    },
    {
      "name": "Markdown Headers",
      "scope": [
        "markup.heading"
      ],
      "settings": {
        "foreground": "#E8A8F0",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown Links",
      "scope": [
        "markup.underline.link"
      ],
      "settings": {
        "foreground": "#F5B8CE"
      }
    },
    {
      "name": "Markdown Code Blocks",
      "scope": [
        "markup.fenced_code.block"
      ],
      "settings": {
        "foreground": "#A0D8E8"
      }
    },
    {
      "name": "Markdown List Items",
      "scope": [
        "markup.list"
      ],
      "settings": {
        "foreground": "#90E0A0"
      }
    },
    {
      "name": "Markdown Emphasis",
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "foreground": "#7A5A78",
        "fontStyle": "italic"
      }
    }
  ]
}
