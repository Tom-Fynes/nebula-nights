{
  "name": "Tokyo Nights",
  "type": "dark",
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "function": "#7AA2F7",
    "method": "#7AA2F7",
    "class": "#FF9E64",
    "module": "#BB9AF7",
    "parameter": "#E0AF68",
    "variable": "#C0CAF5",
    "property": "#73DACA",
    "type": "#2AC3DE",
    "enum": "#73DACA",
    "interface": "#2AC3DE"
  },
  "colors": {
    "editor.background": "#1A1B2E",
    "editor.foreground": "#C0CAF5",
    "activityBarBadge.background": "#F7768E",
    "sideBarTitle.foreground": "#C0CAF5",
    "activityBar.background": "#0E0F20",
    "activityBar.foreground": "#C0CAF5",
    "activityBar.inactiveForeground": "#3B4261",
    "activityBar.activeBorder": "#7AA2F7",
    "sideBar.background": "#16172A",
    "sideBar.foreground": "#C0CAF5",
    "sideBarSectionHeader.background": "#1F2035",
    "sideBarSectionHeader.foreground": "#C0CAF5",
    "editorGroupHeader.tabsBackground": "#16172A",
    "tab.activeBackground": "#1A1B2E",
    "tab.inactiveBackground": "#16172A",
    "tab.activeForeground": "#C0CAF5",
    "tab.inactiveForeground": "#3B4261",
    "tab.activeBorderTop": "#7AA2F7",
    "statusBar.background": "#0E0F20",
    "statusBar.foreground": "#C0CAF5",
    "statusBar.noFolderBackground": "#0E0F20",
    "statusBar.debuggingBackground": "#F7768E",
    "titleBar.activeBackground": "#0E0F20",
    "titleBar.activeForeground": "#C0CAF5",
    "menubar.selectionBackground": "#1F2035",
    "menubar.selectionForeground": "#C0CAF5",
    "menu.background": "#16172A",
    "menu.foreground": "#C0CAF5",
    "menu.selectionBackground": "#1F2035",
    "menu.selectionForeground": "#C0CAF5",
    "quickInput.background": "#16172A",
    "quickInput.foreground": "#C0CAF5",
    "editorWidget.background": "#16172A",
    "editorWidget.foreground": "#C0CAF5",
    "notifications.background": "#16172A",
    "notifications.foreground": "#C0CAF5",
    "breadcrumb.background": "#1A1B2E",
    "breadcrumb.foreground": "#C0CAF5",
    "progressBar.background": "#7AA2F7",
    "terminal.background": "#1A1B2E",
    "terminal.foreground": "#C0CAF5",
    "terminal.ansiBlack": "#16172A",
    "terminal.ansiBlue": "#7AA2F7",
    "terminal.ansiCyan": "#2AC3DE",
    "terminal.ansiGreen": "#9ECE6A",
    "terminal.ansiMagenta": "#BB9AF7",
    "terminal.ansiRed": "#F7768E",
    "terminal.ansiWhite": "#C0CAF5",
    "terminal.ansiYellow": "#E0AF68",
    "terminal.ansiBrightBlack": "#3B4261",
    "terminal.ansiBrightBlue": "#7AA2F7",
    "terminal.ansiBrightCyan": "#89DDFF",
    "terminal.ansiBrightGreen": "#9ECE6A",
    "terminal.ansiBrightMagenta": "#BB9AF7",
    "terminal.ansiBrightRed": "#F7768E",
    "terminal.ansiBrightWhite": "#C0CAF5",
    "terminal.ansiBrightYellow": "#FF9E64",
    "editorBracketHighlight.foreground1": "#7AA2F7",
    "editorBracketHighlight.foreground2": "#BB9AF7",
    "editorBracketHighlight.foreground3": "#2AC3DE",
    "editorBracketHighlight.foreground4": "#73DACA",
    "editorBracketHighlight.foreground5": "#89DDFF",
    "editorBracketHighlight.foreground6": "#9ECE6A",
    "editorError.foreground": "#F7768E",
    "editorWarning.foreground": "#E0AF68",
    "editorInfo.foreground": "#2AC3DE",
    "editorHint.foreground": "#565F89",
    "editorLineHighlight.background": "#1F203533",
    "editor.selectionBackground": "#3B426166",
    "editor.wordHighlightBackground": "#73DACA33",
    "editor.wordHighlightStrongBackground": "#7AA2F733"
  },
  "tokenColors": [
    {
      "name": "Comments",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "foreground": "#565F89"
      }
    },
    {
      "name": "String",
      "scope": ["string", "constant.other.symbol"],
      "settings": {
        "foreground": "#9ECE6A"
      }
    },
    {
      "name": "Keywords",
      "scope": [
        "keyword",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#BB9AF7"
      }
    },
    {
      "name": "Functions",
      "scope": [
        "entity.name.function",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#7AA2F7"
      }
    },
    {
      "name": "Function parameters",
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#E0AF68"
      }
    },
    {
      "name": "Function calls",
      "scope": [
        "variable.function",
        "meta.function-call.generic"
      ],
      "settings": {
        "foreground": "#7AA2F7",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Variables",
      "scope": [
        "variable",
        "support.variable"
      ],
      "settings": {
        "foreground": "#C0CAF5"
      }
    },
    {
      "name": "Classes",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace",
        "entity.name.scope-resolution"
      ],
      "settings": {
        "foreground": "#FF9E64"
      }
    },
    {
      "name": "Numbers",
      "scope": "constant.numeric",
      "settings": {
        "foreground": "#FF9E64"
      }
    },
    {
      "name": "Constants",
      "scope": "constant",
      "settings": {
        "foreground": "#F7768E"
      }
    },
    {
      "name": "Tags",
      "scope": "entity.name.tag",
      "settings": {
        "foreground": "#F7768E"
      }
    },
    {
      "name": "Attributes",
      "scope": "entity.other.attribute-name",
      "settings": {
        "foreground": "#C0CAF5"
      }
    },
    {
      "name": "JSON Property Names",
      "scope": "support.type.property-name.json",
      "settings": {
        "foreground": "#E0AF68"
      }
    },
    {
      "name": "JSON Property Values",
      "scope": "string.quoted.double.json",
      "settings": {
        "foreground": "#9ECE6A"
      }
    },
    {
      "name": "JSON Punctuation",
      "scope": [
        "punctuation.support.type.property-name.begin.json",
        "punctuation.support.type.property-name.end.json",
        "punctuation.separator.dictionary.key-value.json",
        "punctuation.definition.dictionary.begin.json",
        "punctuation.definition.dictionary.end.json",
        "punctuation.definition.array.begin.json",
        "punctuation.definition.array.end.json"
      ],
      "settings": {
        "foreground": "#BB9AF7"
      }
    },
    {
      "name": "Operators",
      "scope": "keyword.operator",
      "settings": {
        "foreground": "#89DDFF"
      }
    },
    {
      "name": "Method calls",
      "scope": "meta.method-call entity.name.function",
      "settings": {
        "foreground": "#7AA2F7"
      }
    },
    {
      "name": "Method definition",
      "scope": "meta.method entity.name.function",
      "settings": {
        "foreground": "#7AA2F7"
      }
    },
    {
      "name": "Function definition",
      "scope": "meta.definition.function entity.name.function",
      "settings": {
        "foreground": "#7AA2F7"
      }
    },
    {
      "name": "SQL Keywords",
      "scope": [
        "keyword.control.flow.sql",
        "keyword.control.import.sql",
        "keyword.operator.logical.sql"
      ],
      "settings": {
        "foreground": "#BB9AF7",
        "fontStyle": "bold"
      }
    },
    {
      "name": "SQL Functions",
      "scope": [
        "support.function.builtin.sql"
      ],
      "settings": {
        "foreground": "#7AA2F7"
      }
    },
    {
      "name": "SQL Variables",
      "scope": [
        "variable.parameter.function.sql"
      ],
      "settings": {
        "foreground": "#E0AF68"
      }
    },
    {
      "name": "SQL Constants",
      "scope": [
        "constant.language.sql"
      ],
      "settings": {
        "foreground": "#F7768E",
        "fontStyle": "bold"
      }
    },
    {
      "name": "SQL Operators",
      "scope": [
        "keyword.operator.sql"
      ],
      "settings": {
        "foreground": "#89DDFF"
      }
    },
    {
      "name": "SQL Table names",
      "scope": [
        "entity.name.type.table.sql"
      ],
      "settings": {
        "foreground": "#FF9E64",
        "fontStyle": "bold"
      }
    },
    {
      "name": "SQL Column names",
      "scope": [
        "entity.name.type.column.sql"
      ],
      "settings": {
        "foreground": "#C0CAF5"
      }
    },
    {
      "name": "SQL String",
      "scope": [
        "string.quoted.single.sql",
        "string.quoted.double.sql"
      ],
      "settings": {
        "foreground": "#9ECE6A"
      }
    },
    {
      "name": "SQL Comments",
      "scope": [
        "comment.line.sql",
        "punctuation.definition.comment.sql"
      ],
      "settings": {
        "foreground": "#565F89"
      }
    },
    {
      "name": "SQL Punctuation",
      "scope": [
        "punctuation.definition.sql"
      ],
      "settings": {
        "foreground": "#BB9AF7"
      }
    },
    {
      "name": "Python decorators",
      "scope": [
        "meta.decorator.python",
        "entity.name.function.decorator.python"
      ],
      "settings": {
        "foreground": "#BB9AF7",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Python function parameters",
      "scope": [
        "variable.parameter.function.python"
      ],
      "settings": {
        "foreground": "#E0AF68"
      }
    },
    {
      "name": "Python function call",
      "scope": [
        "meta.function-call.python",
        "meta.function-call.generic.python"
      ],
      "settings": {
        "foreground": "#7AA2F7"
      }
    },
    {
      "name": "Python builtin functions",
      "scope": [
        "support.function.builtin.python"
      ],
      "settings": {
        "foreground": "#2AC3DE",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Python self parameter",
      "scope": [
        "variable.parameter.function.language.special.self.python",
        "variable.language.special.self.python"
      ],
      "settings": {
        "foreground": "#FF9E64",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Python class definitions",
      "scope": [
        "entity.name.type.class.python"
      ],
      "settings": {
        "foreground": "#FF9E64",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Python module import",
      "scope": [
        "meta.import.python",
        "entity.name.namespace.python"
      ],
      "settings": {
        "foreground": "#BB9AF7"
      }
    },
    {
      "name": "Python f-string expressions",
      "scope": [
        "meta.fstring.python",
        "constant.character.format.placeholder.other.python"
      ],
      "settings": {
        "foreground": "#9ECE6A"
      }
    },
    {
      "name": "Python docstrings",
      "scope": [
        "string.quoted.docstring.multi.python"
      ],
      "settings": {
        "foreground": "#565F89",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Python magic methods",
      "scope": [
        "support.function.magic.python"
      ],
      "settings": {
        "foreground": "#2AC3DE",
        "fontStyle": "bold italic"
      }
    },
    {
      "name": "Python type hints",
      "scope": [
        "meta.function.annotation.return.python",
        "meta.function.parameters.annotation.python",
        "support.type.python"
      ],
      "settings": {
        "foreground": "#2AC3DE"
      }
    },
    {
      "name": "Python constants (True, False, None)",
      "scope": [
        "constant.language.python"
      ],
      "settings": {
        "foreground": "#F7768E",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Python exceptions",
      "scope": [
        "support.type.exception.python"
      ],
      "settings": {
        "foreground": "#F7768E",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Python keywords",
      "scope": [
        "keyword.control.flow.python",
        "keyword.control.import.python",
        "keyword.operator.logical.python"
      ],
      "settings": {
        "foreground": "#BB9AF7",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Python string interpolation",
      "scope": [
        "constant.character.format.placeholder.other.python"
      ],
      "settings": {
        "foreground": "#E0AF68"
      }
    },
    {
      "name": "Python list/dict comprehension",
      "scope": [
        "meta.comprehension.python"
      ],
      "settings": {
        "foreground": "#C0CAF5"
      }
    },
    {
      "name": "Python lambda expressions",
      "scope": [
        "meta.lambda-function.python"
      ],
      "settings": {
        "foreground": "#BB9AF7"
      }
    },
    {
      "name": "TypeScript/JavaScript interfaces",
      "scope": [
        "entity.name.type.interface"
      ],
      "settings": {
        "foreground": "#2AC3DE",
        "fontStyle": "bold"
      }
    },
    {
      "name": "TypeScript/JavaScript enums",
      "scope": [
        "entity.name.type.enum"
      ],
      "settings": {
        "foreground": "#73DACA",
        "fontStyle": "bold"
      }
    },
    {
      "name": "HTML and XML attributes",
      "scope": [
        "entity.other.attribute-name.html",
        "entity.other.attribute-name.xml"
      ],
      "settings": {
        "foreground": "#73DACA"
      }
    },
    {
      "name": "CSS Properties",
      "scope": [
        "support.type.property-name.css",
        "support.type.property-name.scss"
      ],
      "settings": {
        "foreground": "#89DDFF"
      }
    },
    {
      "name": "CSS Values",
      "scope": [
        "support.constant.property-value.css"
      ],
      "settings": {
        "foreground": "#4A8090"
      }
    },
    {
      "name": "Markdown Headers",
      "scope": [
        "markup.heading"
      ],
      "settings": {
        "foreground": "#BB9AF7",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown Links",
      "scope": [
        "markup.underline.link"
      ],
      "settings": {
        "foreground": "#7AA2F7"
      }
    },
    {
      "name": "Markdown Code Blocks",
      "scope": [
        "markup.fenced_code.block"
      ],
      "settings": {
        "foreground": "#89DDFF"
      }
    },
    {
      "name": "Markdown List Items",
      "scope": [
        "markup.list"
      ],
      "settings": {
        "foreground": "#9ECE6A"
      }
    },
    {
      "name": "Markdown Emphasis",
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "foreground": "#565F89",
        "fontStyle": "italic"
      }
    }
  ]
}
