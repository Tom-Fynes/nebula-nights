{
  "name": "nebula-nights-pastel",
  "displayName": "Nebula Nights Pastel",
  "description": "A collection of themes using blues, purples, and pinks — dark, light, sakura, Tokyo Nights, and By the Sea",
  "version": "2.0.0",
  "icon": "resources/Images/nebula.png",
  "publisher": "Tom-Fynes",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Themes"
  ],
  "contributes": {
    "themes": [
      {
        "label": "Nebula Nights",
        "uiTheme": "vs-dark",
        "path": "./themes/nebula-nights-theme.json"
      },
      {
        "label": "Nebula Nights Light",
        "uiTheme": "vs",
        "path": "./themes/nebula-nights-light-theme.json"
      },
      {
        "label": "Sakura",
        "uiTheme": "vs-dark",
        "path": "./themes/sakura-theme.json"
      },
      {
        "label": "Tokyo Nights",
        "uiTheme": "vs-dark",
        "path": "./themes/tokyo-nights-theme.json"
      },
      {
        "label": "By the Sea",
        "uiTheme": "vs",
        "path": "./themes/by-the-sea-theme.json"
      }
    ]
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/tom-fynes/nebula-nights"
  },
  "keywords": [
    "theme",
    "dark theme",
    "light theme",
    "cool",
    "blue",
    "pink",
    "purple",
    "sakura",
    "tokyo nights",
    "ocean"
  ],
  "scripts": {
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@vscode/vsce": "^2.32.0"
  }
}
